{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "hooks": {

    // ──────────────────────────────────────────────────────────────
    // SessionStart: セッション開始・再開時にコンテキストを注入する
    // matcher: "startup"  = 初回起動
    //          "resume"   = 過去セッション再開
    //          "compact"  = コンテキスト圧縮後の再起動
    //          "clear"    = /clear 後の再起動
    // ──────────────────────────────────────────────────────────────
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-context.sh"
          }
        ]
      }
    ],

    // ──────────────────────────────────────────────────────────────
    // PreToolUse: ツール実行前バリデーション
    // exit 2 を返すとツールをブロックできる
    // ──────────────────────────────────────────────────────────────
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/validate-command.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/protect-files.sh"
          }
        ]
      }
    ],

    // ──────────────────────────────────────────────────────────────
    // PostToolUse: ツール実行後の自動処理
    // ──────────────────────────────────────────────────────────────
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/auto-format.sh"
          }
        ]
      }
    ],

    // ──────────────────────────────────────────────────────────────
    // Notification: Claude が入力待ちになったときに通知
    // matcher: "permission_prompt" = 権限確認ダイアログ
    //          "idle_prompt"       = 処理完了・入力待ち
    // ──────────────────────────────────────────────────────────────
    "Notification": [
      {
        "matcher": "permission_prompt|idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/notify.sh"
          }
        ]
      }
    ]
  }
}
